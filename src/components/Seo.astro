---
import { SEO } from 'astro-seo';

interface Props {
    title?: string;
    description?: string;
    ogImage?: string;
}
const {
    title,
    description = 'I post My Hackthebox writeups and other InfoSec findings here.',
    ogImage = 'https://manosriram.com/og.png',
} = Astro.props as Props;
const twitterHandle = '@manosriram';
---

<SEO
    title={title ? `${title} | manosriram` : 'manosriram'}
    description={description}
    openGraph={{
        basic: {
            title: 'manosriram.com',
            type: 'website',
            image: ogImage,
        },
    }}
    twitter={{
        creator: twitterHandle,
        card: 'summary_large_image',
        site: twitterHandle,
        title: 'manosriram',
        description,
        image: ogImage,
        imageAlt: 'manosriram',
    }}
    extend={{
        link: [
            {
                rel: 'sitemap',
                href: '/sitemap-index.xml',
            },
        ],
        meta: [],
    }}
/>
