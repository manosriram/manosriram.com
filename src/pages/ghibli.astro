---
import MainLayout from '../layouts/MainLayout.astro';
import fs from 'fs';
const ghibliImagePaths = fs.readdirSync("public/images/ghibli/");
---

<MainLayout title='ghibli'>
    <div
        class='flex flex-col items-start justify-center max-w-2xl mx-auto mb-16'
    >
		{ghibliImagePaths.map((path: string) => {
		return <img
		src=`/images/ghibli/${path}`
				alt='ghibli-art'
		/>
		<br />
		})}
    </div>
</MainLayout>
