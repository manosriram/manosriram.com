---
import { Picture } from 'astro:assets';
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import Avatar from '../assets/images/avatar.png';
import AllTimeViews from '../components/AllTimeViews';
import BlogPostCard from '../components/BlogPostCard.astro';

const allBlogPosts = await getCollection('blogs');
const sortedPosts = allBlogPosts.sort(
    (a, b) => Number(new Date(b.data.date)) - Number(new Date(a.data.date))
);

const colors = [
    'from-[#D8B4FE] to-[#818CF8]',
    'from-[#6EE7B7] via-[#3B82F6] to-[#9333EA]',
    'from-[#FDE68A] via-[#FCA5A5] to-[#FECACA]',
];
---

<MainLayout>
    <div
        class='flex flex-col justify-center items-start max-w-2xl border-gray-200 dark:border-gray-700 mx-auto pb-16'
    >
        <div class='flex flex-col-reverse sm:flex-row items-start'>
            <div class='flex flex-col pr-8'>
                <h1
                    class='font-bold text-3xl md:text-5xl tracking-tight mb-1 text-black dark:text-white'
                    transition:name='heading'
                >
                    Mano Sriram
                </h1>
                <h2 class='text-gray-700 dark:text-gray-200 mb-4'>
										Curious human who loves writing software.
                </h2>
                <p class='text-gray-600 dark:text-gray-400 mb-8'>
								I work on backend systems - golang, python, and zig;
                </p>

                <p class='text-gray-600 dark:text-gray-400 mb-8'>
								I currently work at <a style="cursor:pointer;" href=https://credshields.com><u>Credshields</u></a>;
								<!-- apart from work, I like writing databases (key-value stores), devtools, and contribute to [dicedb - an inmemory database with query subscriptions](https://github.com/DiceDB/dice). -->
								apart from work - I like writing databases (key-value stores), devtools, and contribute to <a style="cursor: pointer;" href="https://github.com/DiceDB/dice"><u>dicedb (in-memory database)</u></a>.
                </p>


                <p class='text-gray-600 dark:text-gray-400 mb-8'>
								I love <a style="cursor: pointer;" href="https://en.wikipedia.org/wiki/Studio_Ghibli"><u>ghibli</u></a> movies and japanese art - they give me a sense of calmness; few of my favorite shots <a style="cursor: pointer;" href="/ghibli"><u>here</u></a>.
                </p>

                <p class='text-gray-600 dark:text-gray-400 mb-8'>
								You can know more about me via <a style="cursor: pointer;" href="https://github.com/manosriram"><u>github</u></a>, <a style="cursor: pointer;" href="https://x.com/manosriram"><u>x</u></a>, <a style="cursor: pointer;" href="https://linkedin.com/in/manosriram"><u>linkedin</u></a>, or <a style="cursor: pointer;" href="https://youtube.com/@manosriram"><u>youtube</u></a>.
                </p>
						</div>
						<div class='w-[100px] sm:w-[476px] relative mb-8 sm:mb-0 mr-auto'>
								<Picture
												src={Avatar}
												class='rounded-full'
												alt='manosriram'
												formats={['avif', 'webp']}
												/>
						</div>
				</div>
		</div>
</MainLayout>
